# Node + .NET + Python `.gitignore`

```gitignore
# ─────────────────────────────────────────────
# OS
# ─────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─────────────────────────────────────────────
# Environment Variables
# ─────────────────────────────────────────────
.env
.env.*
!.env.example

# ─────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# Virtual environments
.venv/
venv/
env/
ENV/

# Python tooling
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
dist/
build/
*.egg-info/

# Jupyter
.ipynb_checkpoints/

# ─────────────────────────────────────────────
# Node.js
# ─────────────────────────────────────────────
node_modules/
npm-cache/
.pnpm-store/

# Build
dist/
build/
.next/
.nuxt/
.out/
coverage/

# Vite
.vite/

# TypeScript
*.tsbuildinfo

# ─────────────────────────────────────────────
# .NET / C#
# ─────────────────────────────────────────────
bin/
obj/

# Rider / VS / VSCode
.vs/
.idea/
.vscode/

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# NuGet
*.nupkg
packages/

# Publish output
publish/

# Test Results
TestResults/

# ─────────────────────────────────────────────
# Docker
# ─────────────────────────────────────────────
docker-compose.override.yml

# ─────────────────────────────────────────────
# Temporary files
# ─────────────────────────────────────────────
tmp/
temp/
*.tmp
*.swp

# ─────────────────────────────────────────────
# SQLite / Local DBs
# ─────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ─────────────────────────────────────────────
# Mac/Linux permissions
# ─────────────────────────────────────────────
*.pem
*.key

# ─────────────────────────────────────────────
# Generated files
# ─────────────────────────────────────────────
*.cache
.cache/

# ─────────────────────────────────────────────
# Coverage
# ─────────────────────────────────────────────
coverage.xml
lcov.info
```
